# secretos — viven fuera del repo (secrets-management)
.env
.env.*

# imágenes (receipts / screenshots — no versionar binarios pesados)
# para forzar un asset de imagen funcional a futuro: git add -f <archivo>
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico

# deps y build regenerables — NUNCA versionar (no son "info", se regeneran)
node_modules/
**/node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo

# scratch del pipeline
scripts/.fb-snap.txt
scripts/.draft-test.txt
.DS_Store

# RAG: los PDFs originales viven en disco pero NO se versionan (binarios pesados,
# ~10MB). Lo versionable es el TEXTO extraído (doctrine/rag/*.md). git add -f para forzar.
doctrine/rag/*.pdf

# Pipeline scratch (drafts + coagent prompts) — efímeros, no se versionan
scripts/draft-*.txt
scripts/coagent-prompt-*.txt
